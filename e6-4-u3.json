            "grammar": {
                "tips": [
                    {
                        "label": "詢問最喜愛的季節",
                        "text": "What's + 所有格 / 名詞所有格 (如 your, Teddy's) + favorite season?"
                    },
                    {
                        "label": "表達最喜愛的季節",
                        "text": "所有格 (如 My, His, Her) + favorite season is + 季節 (spring, summer, fall, winter)."
                    },
                    {
                        "label": "時間與季節的介系詞",
                        "text": "at + 時間點 / on + 特定日子 / in + 季節或長時間."
                    }
                ],
                "notes": [
                    {
                        "title": "主題一：詢問與回答最喜愛的季節",
                        "rule": "What's = What is。詢問時需正確搭配所有格 (your, his, her) 或名詞所有格 (Teddy's, Mia's)。",
                        "description": "句首疑問詞使用 What，後接動詞 is，再加上表示所屬的代名詞與 favorite season。回答時，只要將問句中的所有格改為對應的第一人稱或第三人稱所有格即可。",
                        "examples": [
                            "What's Mia's favorite season? (Mia 最喜歡的季節是什麼？)",
                            "Her favorite season is summer. (她最喜歡的季節是夏天。)"
                        ]
                    },
                    {
                        "title": "主題二：時間與季節介系詞 in, on, at 的區別",
                        "rule": "in 放「長時間 / 季節 / 月份」；on 放「特定的一天 / 星期」；at 放「明確的時鐘時間點」。",
                        "description": "在描述天氣狀況，或者說明某件事發生在什麼時間時，必須根據時間長短選擇正確的介系詞。",
                        "examples": [
                            "It's hot and wet in summer. (夏天既炎熱又潮濕。) — in 搭配季節",
                            "I play baseball on Sunday. (我在星期日打棒球。) — on 搭配星期",
                            "He goes to bed at 10:00. (他十點上床睡覺。) — at 搭配時間點"
                        ]
                    }
