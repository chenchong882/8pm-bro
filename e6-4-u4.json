            "grammar": {
                "tips": [
                    {
                        "label": "Tip 1",
                        "text": "詢問「單數」物品的價錢時，使用 How much is the + 單數名詞?"
                    },
                    {
                        "label": "Tip 2",
                        "text": "詢問「複數」或「成雙成對」物品（如 pants, jeans, shorts）的價錢時，使用 How much are the + 複數名詞?"
                    },
                    {
                        "label": "Tip 3",
                        "text": "回答單數物品價錢，句首使用 It's... (It is...)"
                    },
                    {
                        "label": "Tip 4",
                        "text": "回答複數物品價錢，句首使用 They're... (They are...)"
                    }
                ],
                "notes": [
                    {
                        "title": "注意 Be 動詞的單複數搭配",
                        "rule": "當主詞是單數名詞（如 hat, dress, T-shirt）時，Be 動詞配 is；當主詞是複數名詞或成雙成對的衣物（如 pants, shorts, jeans）時，Be 動詞配 are。",
                        "description": "注意詢問價錢時，要根據物品的單複數性質來決定動詞。",
                        "examples": [
                            "How much is the hat? (這頂帽子多少錢？)",
                            "How much are the pants? (這件長褲多少錢？)"
                        ]
                    },
                    {
                        "title": "代名詞的正確替換",
                        "rule": "回答價錢時，為了避免重複提到物品名稱，單數物品用 It 代替，複數物品用 They 代替，後面加上價錢。",
                        "description": "答句中代名詞的選擇與原問句中的物品數量息息相關。",
                        "examples": [
                            "How much is the jacket? It is nine dollars. (這件夾克多少錢？它九元。)",
                            "How much are the jeans? They are one hundred dollars. (這件牛仔褲多少錢？它們一百元。)"
                        ]
                    },
                    {
                        "title": "How much 與 How many 的差異",
                        "rule": "How much 用來詢問「價錢（多少錢）」或是「不可數名詞的數量」；How many 則專門用來詢問「可數名詞的數量（有多少個）」。",
                        "description": "本課的重點在於使用 How much 詢問價錢，不要與詢問數量的 How many 搞混。",
                        "examples": [
                            "How much is the coat? (這件外套多少錢？)",
                            "How many coats are there? (那裡有多少件外套？)"
                        ]
                    }
                ],
